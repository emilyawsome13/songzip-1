# Copy this file to .spotdl.env and fill in your own Spotify app credentials.
SPOTDL_CLIENT_ID=your_spotify_client_id
SPOTDL_CLIENT_SECRET=your_spotify_client_secret

# Optional official user-linked OAuth connections for the web UI.
# Register these callback URLs exactly in your Spotify / Google developer apps.
SPOTDL_SPOTIFY_OAUTH_CLIENT_ID=your_spotify_oauth_client_id
SPOTDL_SPOTIFY_OAUTH_CLIENT_SECRET=your_spotify_oauth_client_secret
SPOTDL_SPOTIFY_OAUTH_REDIRECT_URI=http://127.0.0.1:8801/api/auth/callback/spotify

SPOTDL_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
SPOTDL_GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
SPOTDL_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8801/api/auth/callback/youtube

# Optional Google OAuth just for SongZip account sign-in.
# Use only openid/email/profile scopes here, and point this callback at your SongZip site.
SONGZIP_GOOGLE_LOGIN_CLIENT_ID=your_google_login_client_id
SONGZIP_GOOGLE_LOGIN_CLIENT_SECRET=your_google_login_client_secret
SONGZIP_GOOGLE_LOGIN_REDIRECT_URI=http://127.0.0.1:8801/api/account/google/callback

# Optional SongZip admin owner. If omitted, the first Google sign-in claims admin ownership.
SONGZIP_ADMIN_EMAIL=admin@example.com

# Optional PayPal subscription verification for shared SongZip tiers across devices.
# Use sandbox first with https://api-m.sandbox.paypal.com, then switch to production.
SONGZIP_PAYPAL_CLIENT_ID=your_paypal_client_id
SONGZIP_PAYPAL_CLIENT_SECRET=your_paypal_client_secret
SONGZIP_PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
SONGZIP_PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
SONGZIP_PAYPAL_BASIC_PLAN_ID=P-68Y262703G6930321NID6XTQ
SONGZIP_PAYPAL_PLUS_PLAN_ID=P-95499278FS551045NNID6Y2Y
SONGZIP_PAYPAL_PRO_PLAN_ID=P-3HV972983J415051HNID6Z2A
